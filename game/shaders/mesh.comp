#version 450 core

layout(local_size_x = 4, local_size_y = 4, local_size_z = 4) in;

layout(set = 0, binding = 0, r8ui) uniform readonly uimage3D uVoxels;

struct Vertex {
    vec4 pos;
    vec4 color;
    vec4 normal_ao;
    vec4 uv_pad;
};

layout(set = 0, binding = 1, std430) buffer bVertices {
    Vertex vertices[];
};

layout(set = 0, binding = 2, std430) buffer bCounter {
    uint uVertexCount;
};

layout(push_constant) uniform PushConstants {
    ivec2 uChunkPos;
} pc;

const int CHUNK_SIZE = 16;

bool is_transparent(ivec3 p) {
    if (p.x < 0 || p.x >= CHUNK_SIZE || p.y < 0 || p.y >= CHUNK_SIZE || p.z < 0 || p.z >= CHUNK_SIZE) return true;
    return imageLoad(uVoxels, ivec3(p.z, p.y, p.x)).r == 0;
}

struct UVRect { float u, v, w, h; };
UVRect get_uv_rect(uint type) {
    float s = 0.5;
    if (type == 2) return UVRect(0.0, 0.0, s, s); // GRASS
    if (type == 1) return UVRect(s, 0.0, s, s);   // DIRT
    if (type == 3) return UVRect(0.0, s, s, s);   // STONE
    return UVRect(s, s, s, s);
}

void add_face_to_buffer(vec3 p0, vec3 p1, vec3 p2, vec3 p3, vec3 n, float ao, UVRect uv) {
    uint base_idx = atomicAdd(uVertexCount, 6);
    
    // Tri 1
    vertices[base_idx + 0].pos = vec4(p0, 1.0);
    vertices[base_idx + 0].color = vec4(1.0, 1.0, 1.0, 1.0);
    vertices[base_idx + 0].normal_ao = vec4(n, ao);
    vertices[base_idx + 0].uv_pad = vec4(uv.u, uv.v, 0, 0);

    vertices[base_idx + 1].pos = vec4(p1, 1.0);
    vertices[base_idx + 1].color = vec4(1.0, 1.0, 1.0, 1.0);
    vertices[base_idx + 1].normal_ao = vec4(n, ao);
    vertices[base_idx + 1].uv_pad = vec4(uv.u + uv.w, uv.v, 0, 0);

    vertices[base_idx + 2].pos = vec4(p2, 1.0);
    vertices[base_idx + 2].color = vec4(1.0, 1.0, 1.0, 1.0);
    vertices[base_idx + 2].normal_ao = vec4(n, ao);
    vertices[base_idx + 2].uv_pad = vec4(uv.u + uv.w, uv.v + uv.h, 0, 0);

    // Tri 2
    vertices[base_idx + 3].pos = vec4(p0, 1.0);
    vertices[base_idx + 3].color = vec4(1.0, 1.0, 1.0, 1.0);
    vertices[base_idx + 3].normal_ao = vec4(n, ao);
    vertices[base_idx + 3].uv_pad = vec4(uv.u, uv.v, 0, 0);

    vertices[base_idx + 4].pos = vec4(p2, 1.0);
    vertices[base_idx + 4].color = vec4(1.0, 1.0, 1.0, 1.0);
    vertices[base_idx + 4].normal_ao = vec4(n, ao);
    vertices[base_idx + 4].uv_pad = vec4(uv.u + uv.w, uv.v + uv.h, 0, 0);

    vertices[base_idx + 5].pos = vec4(p3, 1.0);
    vertices[base_idx + 5].color = vec4(1.0, 1.0, 1.0, 1.0);
    vertices[base_idx + 5].normal_ao = vec4(n, ao);
    vertices[base_idx + 5].uv_pad = vec4(uv.u, uv.v + uv.h, 0, 0);
}

void main() {
    ivec3 pos = ivec3(gl_GlobalInvocationID.xyz);
    if (pos.x >= CHUNK_SIZE || pos.y >= CHUNK_SIZE || pos.z >= CHUNK_SIZE) return;

    uint type = imageLoad(uVoxels, ivec3(pos.z, pos.y, pos.x)).r;
    if (type == 0) return;

    float ox = float(pos.x + pc.uChunkPos.x * CHUNK_SIZE);
    float oy = float(pos.y);
    float oz = float(pos.z + pc.uChunkPos.y * CHUNK_SIZE);
    UVRect uv = get_uv_rect(type);

    // Front (+Z)
    if (is_transparent(pos + ivec3(0, 0, 1))) {
        add_face_to_buffer(vec3(ox, oy, oz+1), vec3(ox+1, oy, oz+1), vec3(ox+1, oy+1, oz+1), vec3(ox, oy+1, oz+1), vec3(0, 0, 1), 1.0, uv);
    }
    // Back (-Z)
    if (is_transparent(pos + ivec3(0, 0, -1))) {
        add_face_to_buffer(vec3(ox+1, oy, oz), vec3(ox, oy, oz), vec3(ox, oy+1, oz), vec3(ox+1, oy+1, oz), vec3(0, 0, -1), 1.0, uv);
    }
    // Left (-X)
    if (is_transparent(pos + ivec3(-1, 0, 0))) {
        add_face_to_buffer(vec3(ox, oy, oz), vec3(ox, oy, oz+1), vec3(ox, oy+1, oz+1), vec3(ox, oy+1, oz), vec3(-1, 0, 0), 1.0, uv);
    }
    // Right (+X)
    if (is_transparent(pos + ivec3(1, 0, 0))) {
        add_face_to_buffer(vec3(ox+1, oy, oz+1), vec3(ox+1, oy, oz), vec3(ox+1, oy+1, oz), vec3(ox+1, oy+1, oz+1), vec3(1, 0, 0), 1.0, uv);
    }
    // Top (+Y)
    if (is_transparent(pos + ivec3(0, 1, 0))) {
        add_face_to_buffer(vec3(ox, oy+1, oz+1), vec3(ox+1, oy+1, oz+1), vec3(ox+1, oy+1, oz), vec3(ox, oy+1, oz), vec3(0, 1, 0), 1.0, uv);
    }
    // Bottom (-Y)
    if (is_transparent(pos + ivec3(0, -1, 0))) {
        add_face_to_buffer(vec3(ox, oy, oz), vec3(ox+1, oy, oz), vec3(ox+1, oy, oz+1), vec3(ox, oy, oz+1), vec3(0, -1, 0), 1.0, uv);
    }
}
